  <div class="table-wrap"><table><thead><tr><th>Mois</th><th>Saison</th><th>Tarif/nuit</th><th>Nuits</th><th>Occupation</th><th>Revenus</th></tr></thead><tbody id="tbody-scenarios"></tbody></table></div>
