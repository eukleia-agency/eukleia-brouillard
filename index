<script>
const MONTHS = [
  { m:"Avr", tarif:120, days:30, saison:"Mi-saison", act_n:0,  act_tarif:174, plan:4,  cent:8,  plaf:12 },
  { m:"Mai", tarif:130, days:31, saison:"Mi-saison", act_n:0,  act_tarif:174, plan:6,  cent:12, plaf:17 },
  { m:"Jun", tarif:140, days:30, saison:"Mi-saison+",act_n:8,  act_tarif:174, plan:8,  cent:14, plaf:19 },
  { m:"Jul", tarif:165, days:31, saison:"Haute",     act_n:0,  act_tarif:163, plan:15, cent:21, plaf:26 },
  { m:"Aoû", tarif:175, days:31, saison:"Haute",     act_n:0,  act_tarif:170, plan:16, cent:22, plaf:27 },
  { m:"Sep", tarif:130, days:30, saison:"Mi-saison", act_n:0,  act_tarif:174, plan:6,  cent:13, plaf:17 },
  { m:"Oct", tarif:110, days:31, saison:"Mi-saison", act_n:7,  act_tarif:174, plan:4,  cent:8,  plaf:13 },
  { m:"Nov", tarif:95,  days:30, saison:"Basse",     act_n:1,  act_tarif:174, plan:2,  cent:4,  plaf:7  },
  { m:"Déc", tarif:110, days:31, saison:"Mi-saison", act_n:0,  act_tarif:174, plan:4,  cent:7,  plaf:11 },
  { m:"Jan", tarif:95,  days:31, saison:"Basse",     act_n:0,  act_tarif:174, plan:2,  cent:4,  plaf:6  },
  { m:"Fév", tarif:105, days:28, saison:"Mi-saison", act_n:0,  act_tarif:174, plan:4,  cent:7,  plaf:10 },
  { m:"Mar", tarif:100, days:31, saison:"Basse",     act_n:0,  act_tarif:174, plan:3,  cent:5,  plaf:8  },
];

function fmt(n) { return n.toLocaleString('fr-FR'); }
function badgeClass(s) { return s === 'Haute' ? 'badge-haute' : s === 'Basse' ? 'badge-basse' : 'badge-mi'; }
function barColor(s) { return s === 'Haute' ? '#2D6A4F' : s === 'Basse' ? '#8A9BAB' : '#B8975A'; }

function showTab(id) {
  document.querySelectorAll('.content > div[id^="tab-"]').forEach(d => d.classList.add('hidden'));
  document.getElementById('tab-' + id).classList.remove('hidden');
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
}

// TAB 1 — ACTUEL
function buildActuel() {
  const tbody = document.getElementById('tbody-actuel');
  let totN = 0, totR = 0;
  MONTHS.forEach(m => {
    const r = m.act_n * m.act_tarif;
    totN += m.act_n; totR += r;
    const obs = m.act_n === 0 ? '<span class="red">Vide</span>' : m.act_n + ' nuits réservées';
    tbody.innerHTML += `<tr><td class="bold-navy">${m.m}</td><td class="muted">${m.act_tarif} €</td><td class="${m.act_n===0?'red':'bold-navy'}">${m.act_n}</td><td class="muted">${fmt(r)} €</td><td>${obs}</td></tr>`;
  });
  tbody.innerHTML += `<tr class="total-row"><td colspan="2">TOTAL</td><td>${totN}</td><td class="gold">${fmt(totR)} €</td><td></td></tr>`;
}

// TAB 2 — EUKLEIA CENTRAL
function buildEukleia() {
  const tbody = document.getElementById('tbody-eukleia');
  let totN = 0, totR = 0;
  const maxRev = Math.max(...MONTHS.map(m => m.tarif * m.cent));
  MONTHS.forEach(m => {
    const rev = m.tarif * m.cent;
    const occ = Math.round(m.cent / m.days * 100);
    totN += m.cent; totR += rev;
    tbody.innerHTML += `<tr><td class="bold-navy">${m.m}</td><td><span class="badge ${badgeClass(m.saison)}">${m.saison}</span></td><td style="color:#B8975A;font-weight:600">${m.tarif} €</td><td>${m.cent}</td><td><div class="bar-wrap"><div class="bar-fill" style="width:${occ}%;background:${barColor(m.saison)}"></div></div><span class="occ-label">${occ}%</span></td><td class="bold-navy">${fmt(rev)} €</td></tr>`;
  });
  tbody.innerHTML += `<tr class="total-row"><td colspan="3">TOTAL</td><td>${totN} n.</td><td></td><td class="gold">${fmt(totR)} €</td></tr>`;
}

// TAB 3 — COMPARAISON
function buildComparaison() {
  let totAct = 0, totEuk = 0;
  const chartEl = document.getElementById('bar-chart-compare');
  const maxR = Math.max(...MONTHS.map(m => Math.max(m.act_n * m.act_tarif, m.tarif * m.cent)));
  MONTHS.forEach(m => {
    const aR = m.act_n * m.act_tarif;
    const eR = m.tarif * m.cent;
    totAct += aR; totEuk += eR;
    const aPct = maxR > 0 ? Math.round(aR / maxR * 100) : 0;
    const ePct = maxR > 0 ? Math.round(eR / maxR * 100) : 0;
    chartEl.innerHTML += `<div class="bar-row"><div class="bar-month">${m.m}</div><div class="bar-tracks"><div class="bar-track" style="width:${Math.max(aPct,1)}%;background:#B4B2A9"><span class="bar-label">${aR > 0 ? fmt(aR)+'€' : ''}</span></div><div class="bar-track" style="width:${Math.max(ePct,2)}%;background:#2D6A4F"><span class="bar-label">${fmt(eR)} €</span></div></div></div>`;
  });
  document.getElementById('c-act').textContent = fmt(totAct) + ' €';
  document.getElementById('c-euk').textContent = fmt(totEuk) + ' €';
  document.getElementById('c-gain').textContent = '+' + fmt(totEuk - totAct) + ' €';
  document.getElementById('c-mult').textContent = '×' + (totEuk / totAct).toFixed(1) + ' vs actuel';
  const netGain = totEuk * 0.80 - totAct;
  document.getElementById('gain-net').textContent = '+' + fmt(Math.round(netGain)) + ' €';
}

// TAB 4 — SCENARIOS
function getKey(s) { return s === 'plancher' ? 'plan' : s === 'plafond' ? 'plaf' : 'cent'; }
function getLabel(s) { return s === 'plancher' ? 'Scénario plancher' : s === 'plafond' ? 'Scénario plafond' : 'Estimation centrale'; }

function buildScenarioCards() {
  let t = { plan:{n:0,r:0}, cent:{n:0,r:0}, plaf:{n:0,r:0} };
  MONTHS.forEach(m => { ['plan','cent','plaf'].forEach(k => { t[k].n += m[k]; t[k].r += m.tarif * m[k]; }); });
  document.getElementById('sc-plan-val').textContent = fmt(t.plan.r) + ' €';
  document.getElementById('sc-plan-nights').textContent = t.plan.n + ' nuits';
  document.getElementById('sc-plan-occ').textContent = 'Occupation : ' + Math.round(t.plan.n/365*100) + '%';
  document.getElementById('sc-cent-val').textContent = fmt(t.cent.r) + ' €';
  document.getElementById('sc-cent-nights').textContent = t.cent.n + ' nuits';
  document.getElementById('sc-cent-occ').textContent = 'Occupation : ' + Math.round(t.cent.n/365*100) + '%';
  document.getElementById('sc-plaf-val').textContent = fmt(t.plaf.r) + ' €';
  document.getElementById('sc-plaf-nights').textContent = t.plaf.n + ' nuits';
  document.getElementById('sc-plaf-occ').textContent = 'Occupation : ' + Math.round(t.plaf.n/365*100) + '%';
}

function renderScenarioTable(s) {
  const k = getKey(s);
  const tbody = document.getElementById('tbody-scenarios');
  const chart = document.getElementById('bar-chart-scenario');
  document.getElementById('sc-chart-title').textContent = 'Revenus mensuels — ' + getLabel(s);
  tbody.innerHTML = ''; chart.innerHTML = '';
  let totN = 0, totR = 0;
  const maxR = Math.max(...MONTHS.map(m => m.tarif * m[k]));
  MONTHS.forEach(m => {
    const n = m[k], rev = m.tarif * n, occ = Math.round(n/m.days*100);
    totN += n; totR += rev;
    tbody.innerHTML += `<tr><td class="bold-navy">${m.m}</td><td><span class="badge ${badgeClass(m.saison)}">${m.saison}</span></td><td style="color:#B8975A;font-weight:600">${m.tarif} €</td><td>${n}</td><td><div class="bar-wrap"><div class="bar-fill" style="width:${occ}%;background:${barColor(m.saison)}"></div></div><span class="occ-label">${occ}%</span></td><td class="bold-navy">${fmt(rev)} €</td></tr>`;
    const pct = maxR > 0 ? Math.round(rev/maxR*100) : 0;
    chart.innerHTML += `<div class="bar-row"><div class="bar-month">${m.m}</div><div style="flex:1"><div class="bar-track" style="width:${Math.max(pct,2)}%;background:${barColor(m.saison)}"><span class="bar-label">${fmt(rev)} €</span></div></div></div>`;
  });
  tbody.innerHTML += `<tr class="total-row"><td colspan="3">TOTAL</td><td>${totN} n.</td><td></td><td class="gold">${fmt(totR)} €</td></tr>`;
}

function selectScenario(s) {
  document.querySelectorAll('.scenario').forEach(el => el.classList.remove('selected'));
  document.querySelector('.scenario.' + s).classList.add('selected');
  renderScenarioTable(s);
}

buildActuel(); buildEukleia(); buildComparaison(); buildScenarioCards(); selectScenario('central');
</script>
</body>
