    <div class="scenario plafond" onclick="selectScenario('plafond')"><div class="scenario-label">Scénario plafond</div><div class="scenario-value" id="sc-plaf-val">—</div><div class="scenario-nights" id="sc-plaf-nights">—</div><div class="scenario-occup" id="sc-plaf-occ">—</div></div>
