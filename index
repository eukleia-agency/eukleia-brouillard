  .tabs-wrap::-webkit-scrollbar { display: none; }
  .tab { padding: 13px 20px; font-size: 12px; color: #8A9BAB; cursor: pointer; border-bottom: 3px solid transparent; margin-bottom: -2px; transition: all 0.2s; white-space: nowrap; flex-shrink: 0; }
