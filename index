    <div class="kpi accent"><div class="kpi-label">Avec Eukleia</div><div class="kpi-value" id="c-euk">—</div><div class="kpi-sub">125 nuits · 3 plateformes</div></div>
    <div class="kpi dark"><div class="kpi-label">Gain brut annuel</div><div class="kpi-value" id="c-gain">—</div><div class="kpi-sub" id="c-mult">—</div></div>
